# AuctionMethod API
AM_DOMAIN=clientsite.auctionmethod.com
AM_EMAIL=api-user@client.com
AM_PASSWORD=your-password-here

# Optional: if images use a different base URL than AM_DOMAIN (e.g. CDN)
# AM_IMAGE_BASE=https://clientsite.auctionmethod.com

# Supabase (required for sync, browse, auth)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres (required for auto table creation; from Supabase Settings > Database)
POSTGRES_URL=postgres://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# If you get "self-signed certificate in certificate chain", add:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# App
NEXT_PUBLIC_APP_URL=https://bidiq.vercel.app
CRON_SECRET=generate-a-random-secret-here
